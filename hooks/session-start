#!/usr/bin/env bash
# SessionStart hook for nestjs-skills plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-nestjs-skills content
bootstrap_skill_content=$(cat "${PLUGIN_ROOT}/skills/using-nestjs-skills/SKILL.md" 2>&1 || echo "Error reading using-nestjs-skills skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_skill_escaped=$(escape_for_json "$bootstrap_skill_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have nestjs-skills.\n\n**Below is the full content of your 'nestjs-skills:using-nestjs-skills' skill. It is already loaded for this session. Use the Skill tool for the other skills in this repository.**\n\n${bootstrap_skill_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
