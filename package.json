{
  "name": "nimbou-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Claude Code and Codex skill library with a NestJS backend core and prefixed Nuxt/Vuetify frontend skills",
  "type": "module",
  "bin": {
    "nb-catalog": "./bin/nb-catalog"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "catalog": "tsx plugins/nimbou-skills/skills/nuxt-catalog/scripts/generate-catalog.ts",
    "nb-catalog:validate": "tsx plugins/nimbou-skills/skills/nuxt-catalog/scripts/generate-catalog.ts --validate"
  },
  "keywords": [
    "claude",
    "nestjs",
    "prisma",
    "clean-architecture",
    "solid",
    "nuxt",
    "vuetify",
    "skills"
  ],
  "devDependencies": {
    "@vue/compiler-sfc": "^3.5.13",
    "fast-glob": "^3.3.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vue-component-meta": "^3.1.2"
  }
}
